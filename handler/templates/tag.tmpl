<!DOCTYPE html>
<html lang="{{.Lang}}">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>{{.Title}}</title>
<meta property="og:title" content="{{.Title}}">
<meta property="og:type" content="website">
<meta property="og:site_name" content="{{.Domain}}">
{{if .RobotsContent}}<meta name="robots" content="{{.RobotsContent}}">
{{end}}<link rel="icon" type="image/svg+xml" href="/favicon.svg">
<link rel="stylesheet" href="/assets/index.css?v=moefkg9j">
<link id="theme-css-default" rel="stylesheet" href="{{.ThemeCSS}}">
</head>
<style>body.ssr #app{opacity:0}@media(prefers-color-scheme:dark){body.ssr{background:#161618}}</style>
<body class="ssr">
<div id="app">
  <div class="ssr-content">
    <div class="screen">
      <div class="card" style="padding:0">
        <div class="profile-body">
          <h1>#{{.Tag}}</h1>
        </div>
      </div>
      <div class="posts">
      {{if .Posts}}
      {{range .Posts}}
      <article class="card">
        <div class="post-header">
          <a href="{{.Permalink}}"><time datetime="{{.CreatedAt.Format "2006-01-02T15:04:05Z07:00"}}">{{.CreatedAt.Format "2006-01-02 15:04"}}</time></a>
        </div>
        <div class="post-content">{{.Content}}</div>
      </article>
      {{end}}
      {{else}}
      <p class="empty">{{call .T "public.no_posts"}}</p>
      {{end}}
      </div>
    </div>
  </div>
</div>
<script id="ssr-data" type="application/json">{{.SSRData}}</script>
<script type="module" src="/assets/index.js?v=moefkg9j"></script>
</body>
</html>
