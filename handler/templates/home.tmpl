<!DOCTYPE html>
<html lang="{{.Lang}}">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>{{.Title}}</title>
<meta property="og:title" content="{{.Title}}">
<meta property="og:type" content="website">
<meta property="og:image" content="{{.BaseURL}}/ogp.png">
<meta property="og:site_name" content="{{.Domain}}">
{{if .RobotsContent}}<meta name="robots" content="{{.RobotsContent}}">
{{end}}<link rel="icon" type="image/svg+xml" href="/favicon.svg">
<link rel="stylesheet" href="/assets/index.css?v=moedgr56">
<link id="theme-css-default" rel="stylesheet" href="{{.ThemeCSS}}">
</head>
<style>body.ssr #app{opacity:0}@media(prefers-color-scheme:dark){body.ssr{background:#161618}}</style>
<body class="ssr">
<div id="app">
  <div class="ssr-content">
    {{range .Personas}}
    <div class="screen">
      <div class="card" style="padding:0">
        {{if .HeaderURL}}<div class="profile-header"><img src="{{.HeaderURL}}" alt=""></div>{{end}}
        <div class="profile-body">
          <div class="profile-identity">
            {{if .AvatarURL}}<img class="avatar" src="{{.AvatarURL}}" alt="{{.DisplayName}}">{{end}}
            <div class="profile-name">
              <h1><a href="{{.ProfileURL}}">{{.DisplayName}}</a></h1>
              <p class="handle">@{{.Username}}@{{$.Domain}}</p>
            </div>
          </div>
          {{if .Summary}}<div class="bio">{{.Summary}}</div>{{end}}
          {{if .Fields}}
          <dl class="profile-fields">
            {{range .Fields}}
            <div class="profile-field">
              <dt>{{.Name}}</dt>
              <dd>{{.Value}}</dd>
            </div>
            {{end}}
          </dl>
          {{end}}
        </div>
      </div>
      <div class="posts">
      {{if .Posts}}
      {{range .Posts}}
      <article class="card">
        <div class="post-header">
          <div class="post-author">
            <span class="post-author-name">{{$.Title}}</span>
          </div>
          <a href="{{.Permalink}}"><time datetime="{{.CreatedAt.Format "2006-01-02T15:04:05Z07:00"}}">{{.CreatedAt.Format "2006-01-02 15:04"}}</time></a>
        </div>
        <div class="post-content">{{.Content}}</div>
      </article>
      {{end}}
      {{end}}
      </div>
    </div>
    {{end}}
  </div>
</div>
<script id="ssr-data" type="application/json">{{.SSRData}}</script>
<script type="module" src="/assets/index.js?v=moedgr56"></script>
</body>
</html>
